# ─── SMTP Email (required for form notifications) ───────────────────────────
SMTP_HOST=mail.bertiefoundation.org
SMTP_EMAIL=info@bertiefoundation.org
SMTP_PASSWORD=your_smtp_password_here
SMTP_PORT=465

# ─── Supabase (optional - forms work without it, but no DB storage) ─────────
# Create a project at https://supabase.com and paste these here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── App settings ────────────────────────────────────────────────────────────
APP_BASE_URL=https://bertiefoundation.org
ENVIRONMENT=production

# ─── CORS - comma-separated list of allowed frontend origins ─────────────────
# For Railway/Vercel deployment, add your deployed frontend URL here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://bertiefoundation.org
